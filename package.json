{
  "name": "testblox",
  "version": "1.0.3",
  "description": "TestBlox - no-code test automation with Git integration",
  "main": "electron/main.js",
  "private": true,
  "scripts": {
    "postinstall": "playwright install chromium",
    "start": "electron .",
    "dev": "electron .",
    "build:frontend": "cd frontend && npm ci && npm run build && node -e \"require('fs').cpSync('dist', '../renderer', {recursive: true, force: true})\"",
    "prepare-bundled-browser": "node scripts/prepare-bundled-browser.js",
    "build": "npm run build:frontend && npm run prepare-bundled-browser && electron-builder --win && node scripts/copy-release-exe.js",
    "build:dir": "npm run build:frontend && npm run prepare-bundled-browser && electron-builder --win --dir",
    "pack": "electron-builder --win --dir"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "axios": "1.13.6",
    "dotenv": "^17.4.0",
    "electron-is-dev": "^2.0.0",
    "extract-zip": "^2.0.1",
    "git-url-parse": "^14.1.0",
    "jsdom": "^25.0.0",
    "playwright": "^1.49.0",
    "randexp": "^0.5.3",
    "simple-git": "^3.22.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.testblox.desktop",
    "productName": "TestBlox",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "renderer/**/*"
    ],
    "extraResources": [
      {
        "from": "dist-bundled-browser",
        "to": "bundled-browser"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
